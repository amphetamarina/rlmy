# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/

# Runtime data (personal workspaces, trajectories, session state)
sandbox/*
!sandbox/.gitkeep
filesystem*/
backups/
.cache.json
prototype/.trajectory_state.jsonl

# MCP config with secrets (use mcp_servers.example.json as template)
mcp_servers.json
!mcp_servers.example.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Legacy files (not part of the portable codebase)
# NOTE: anchored with a leading slash so this only matches a root-level main.py,
# NOT src/rlmy/agent/main.py (the live CLI entrypoint, which MUST be tracked).
/main.py
tests/spike*

# Local-only files (archives, dev journals, scratchpads)
local/
uv.lock
